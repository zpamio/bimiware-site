---
import { SITE } from '../data/site';
---

<header class="site-header">
  <div class="container">
    <a class="wordmark" href="/">Bimi<span>ware</span></a>
    <nav class="nav" aria-label="Primary">
      <a href="/#services" class="hide-sm">Services</a>
      <a href="/guides" class="hide-sm">Guides</a>
      <a href="/tools" class="hide-sm">Tools</a>
      <a class="btn btn-primary" href="/services/bimi-svg-fix">Fix my SVG</a>
    </nav>
  </div>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('a[href="/services/bimi-svg-fix"].btn').forEach(function (el) {
      el.addEventListener('click', function () {
        window.posthog?.capture('fix_svg_header_clicked', {
          location: 'header',
        });
      });
    });
  });
</script>
