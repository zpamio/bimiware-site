---
// Consent-first analytics. The CMP renders for everyone; PostHog is only
// loaded and initialised if the visitor accepts the analytics category, so
// it never touches first paint and never runs without consent.
//
// Configure with PUBLIC_ env vars (safe to expose; the PostHog project key
// is a publishable ingest key, not a secret):
//   PUBLIC_POSTHOG_KEY   your PostHog project API key
//   PUBLIC_POSTHOG_HOST  defaults to the EU region
// With no key set, the banner still works and PostHog is simply a no-op.
import 'vanilla-cookieconsent/dist/cookieconsent.css';
---

<script>
  import * as CookieConsent from 'vanilla-cookieconsent';

  const POSTHOG_KEY = import.meta.env.PUBLIC_POSTHOG_KEY;
  const POSTHOG_HOST = import.meta.env.PUBLIC_POSTHOG_HOST || 'https://eu.i.posthog.com';

  let posthog = null;

  async function enableAnalytics() {
    if (!POSTHOG_KEY) return;
    if (!posthog) {
      // Lazy-load PostHog only on consent, keeping it out of the page bundle.
      posthog = (await import('posthog-js')).default;
      posthog.init(POSTHOG_KEY, {
        api_host: POSTHOG_HOST,
        person_profiles: 'identified_only',
        capture_pageview: true,
      });
    } else {
      posthog.opt_in_capturing();
    }
  }

  function disableAnalytics() {
    if (posthog) posthog.opt_out_capturing();
  }

  CookieConsent.run({
    guiOptions: {
      consentModal: { layout: 'box', position: 'bottom left' },
      preferencesModal: { layout: 'box' },
    },
    categories: {
      necessary: { readOnly: true, enabled: true },
      analytics: {},
    },
    language: {
      default: 'en',
      translations: {
        en: {
          consentModal: {
            title: 'Cookies',
            description:
              'We use privacy-friendly analytics to understand how this site is used. You can accept or decline.',
            acceptAllBtn: 'Accept',
            acceptNecessaryBtn: 'Decline',
            showPreferencesBtn: 'Manage',
          },
          preferencesModal: {
            title: 'Consent preferences',
            acceptAllBtn: 'Accept all',
            acceptNecessaryBtn: 'Reject all',
            savePreferencesBtn: 'Save preferences',
            closeIconLabel: 'Close',
            sections: [
              {
                title: 'Necessary',
                description: 'Required for the site to function. Always on.',
                linkedCategory: 'necessary',
              },
              {
                title: 'Analytics',
                description: 'PostHog product and web analytics. Helps us improve the site.',
                linkedCategory: 'analytics',
              },
            ],
          },
        },
      },
    },
    onConsent() {
      if (CookieConsent.acceptedCategory('analytics')) enableAnalytics();
    },
    onChange() {
      if (CookieConsent.acceptedCategory('analytics')) enableAnalytics();
      else disableAnalytics();
    },
  });
</script>
